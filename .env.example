# Brevo Newsletter Configuration
# Add these to your Vercel Environment Variables

# Your Brevo API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Double Opt-in Template ID from Brevo (usually 2)
BREVO_DOI_TEMPLATE_ID=2

# Newsletter Pending List ID from Brevo (DOI pending list)
BREVO_NEWSLETTER_LIST_ID=4

# URL where users are redirected after confirming their email
BREVO_DOI_REDIRECT_URL=https://aiseo.hamburg/newsletter/confirmed

# SMTP Configuration for contact form
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_ANMELDUNG=your_smtp_login
BREVO_SMTP_KEY=your_smtp_password

# Email address to receive contact form submissions
CONTACT_RECIPIENT_EMAIL=your-email@gmail.com